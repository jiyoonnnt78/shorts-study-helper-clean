# ===== Backend 환경변수 =====
# 비밀값은 이 파일이 아닌 .env에만 넣고, .env는 git에 올리지 않는다.

# DB (개발: SQLite / 운영: postgresql+psycopg://user:pw@host:5432/dbname)
DATABASE_URL=sqlite:///./data/app.db

# 파일 저장 위치 (서버 내부 경로)
MEDIA_ROOT=./media

# 브라우저가 캡쳐 이미지를 가져올 공개 URL prefix
PUBLIC_MEDIA_URL=/media

# 업로드 제한
MAX_UPLOAD_MB=100
MAX_VIDEO_DURATION_SECONDS=60

# 분석 옵션 (무거우면 false로)
ENABLE_OCR=true
ENABLE_STT=true
WHISPER_MODEL=tiny

# 한국어 형태소 분석기(Kiwi)로 명사 키워드 추출 정확도 높이기 (선택)
# true면 kiwipiepy 사용. "나를", "벌써", "정말", "여러분을" 같은
# 조사/부사/대명사를 품사 단계에서 자동 제외한다.
# kiwipiepy 미설치/실행 실패 시 자동으로 규칙 기반 추출로 fallback하므로 안전하다.
# 사용하려면: pip install kiwipiepy 후 아래를 true로 설정.
ENABLE_KIWI=true

# CORS (쉼표 구분, 운영에서는 실제 프론트 도메인으로 교체)
CORS_ORIGINS=http://localhost:3000
