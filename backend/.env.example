# ===== Backend 환경변수 =====
# 비밀값은 이 파일이 아닌 .env에만 넣고, .env는 git에 올리지 않는다.

# DB (개발: SQLite / 운영: postgresql+psycopg://user:pw@host:5432/dbname)
DATABASE_URL=sqlite:///./data/app.db

# 파일 저장 위치 (서버 내부 경로)
MEDIA_ROOT=./media

# 브라우저가 캡쳐 이미지를 가져올 공개 URL prefix
PUBLIC_MEDIA_URL=/media

# 업로드 제한
MAX_UPLOAD_MB=100
MAX_VIDEO_DURATION_SECONDS=60

# 분석 옵션 (무거우면 false로)
ENABLE_OCR=true
ENABLE_STT=true
WHISPER_MODEL=tiny

# 한국어 형태소 분석기(Kiwi)로 명사 키워드 추출 정확도 높이기 (선택)
# true면 kiwipiepy 사용. "나를", "벌써", "정말", "여러분을" 같은
# 조사/부사/대명사를 품사 단계에서 자동 제외한다.
# kiwipiepy 미설치/실행 실패 시 자동으로 규칙 기반 추출로 fallback하므로 안전하다.
# 사용하려면: pip install kiwipiepy 후 아래를 true로 설정.
ENABLE_KIWI=true
# 메타데이터 전용(YouTube 링크) 분석에서 Kiwi 사용 여부. 메모리 빠듯하면 false 권장.
KIWI_FOR_METADATA_ONLY=false

# CORS (쉼표 구분, 운영에서는 실제 프론트 도메인으로 교체)
CORS_ORIGINS=http://localhost:3000
# Vercel preview 도메인 등 패턴 허용 (배포마다 바뀌는 도메인 대비)
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# --- YouTube 링크 분석 ---
# 링크 분석 기능 켜기 (끄면 /api/youtube/analyze 비활성)
ENABLE_YOUTUBE=true
# 영상 파일 다운로드(yt-dlp) 허용 여부. 약관 이슈로 기본 꺼짐.
# 꺼져 있으면 제목/설명/썸네일 기반 사전 분석만 수행한다.
# true로 켜면 영상을 저화질로 받아 핵심 4구간(오프닝/전개/클라이맥스/마무리)
# 스크린샷+OCR로 상세 분석한다. STT/whisper는 사용 안 함(메모리 절약). 30초 데드라인.
ENABLE_YOUTUBE_DOWNLOAD=true

# --- LLM 분석 (선택) ---
# 켜고 키를 넣으면 LLM으로 더 풍부한 분석(요약·구성·몰입요소·맞춤 제작팁)을 시도한다.
# 키가 없거나 호출 실패 시 자동으로 무료 규칙 기반 분석으로 fallback한다.
ENABLE_LLM_ANALYSIS=false
LLM_PROVIDER=openai          # openai / anthropic
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=                 # 비우면 제공자 기본 엔드포인트
LLM_TIMEOUT_SECONDS=30
